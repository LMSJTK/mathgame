    { "id": "coin_3", "type": "collectible", "x": 750, "y": 380, "properties": { "value": 10 } }
  ],
  "triggers": [
    {
      "id": "welcome_trigger",
      "condition": { "type": "on_level_start" },
      "actions": [
        { "type": "play_dialogue", "params": { "dialogueId": "dlg_welcome" } }
      ],
      "once": true
    },
    {
      "id": "bridge_hint",
      "condition": {
        "type": "on_enter_region",
        "params": { "x": 80, "y": 760, "w": 200, "h": 100 }
      },
      "actions": [
        { "type": "show_text", "params": { "text": "This glowing zone opens a Bridge Build challenge. Combine tiles to match the target!" } }
      ],
      "once": true
    },
    {
      "id": "midway_encouragement",
      "condition": { "type": "on_checkpoint" },
      "actions": [
        { "type": "show_text", "params": { "text": "Good progress! Keep climbing." } }
      ],
      "once": false
    },
    {
      "id": "streak_bonus",
      "condition": {
        "type": "on_correct_streak",
        "params": { "count": 2 }
      },
      "actions": [
        { "type": "show_text", "params": { "text": "Streak bonus! You're on fire!" } }
      ],
      "once": false
    },
    {
      "id": "all_done",
      "condition": { "type": "on_all_encounters_complete" },
      "actions": [
        { "type": "unlock_path", "params": { "entityId": "exit" } },
        { "type": "play_dialogue", "params": { "dialogueId": "dlg_allclear" } }
      ],
      "once": true
    }
  ],
  "mathEncounters": [
    {
      "id": "enc_bridge",
      "encounterType": "bridge_build",
      "skill": "addition_subtraction",
      "difficulty": "easy",
      "successTarget": 1,
      "failureLimit": 3,
      "linkedEntityId": "eq_bridge",
      "reward": { "type": "progress", "amount": 1 },
      "remediation": { "onFailure": "show_hint_then_retry" }
    },
    {
      "id": "enc_route",
      "encounterType": "route_logic",
      "skill": "multiplication_division",
      "difficulty": "medium",
      "successTarget": 1,
      "failureLimit": 3,
      "linkedEntityId": "eq_route",
      "reward": { "type": "progress", "amount": 1 },
      "remediation": { "onFailure": "show_hint_then_retry" }
    },
    {
      "id": "enc_sequence",
      "encounterType": "sequence_repair",
      "skill": "addition_subtraction",
      "difficulty": "medium",
      "successTarget": 1,
      "failureLimit": 3,
      "linkedEntityId": "eq_sequence",
      "reward": { "type": "progress", "amount": 1 },
      "remediation": { "onFailure": "show_hint_then_retry" }
    },
    {
      "id": "enc_gate",
      "encounterType": "gate_unlock",
      "skill": "exponents",
      "difficulty": "easy",
      "successTarget": 1,
      "failureLimit": 3,
      "linkedEntityId": "eq_gate",
      "reward": { "type": "progress", "amount": 1 },
      "remediation": { "onFailure": "show_hint_then_retry" }
    }
  ],
  "dialogue": [
    {
      "id": "dlg_welcome",
      "speaker": "Professor Pi",
      "lines": [
        { "text": "Welcome to the Logic Tower!", "emotion": "happy", "duration": 2.5 },
        { "text": "This tower has different kinds of challenges. Build bridges, route numbers, and repair sequences.", "emotion": "neutral", "duration": 4.0 },
        { "text": "Climb to the top and solve them all to unlock the exit. Good luck!", "emotion": "celebrating", "duration": 3.0 }
      ]
    },
    {
      "id": "dlg_allclear",
      "speaker": "Professor Pi",
      "lines": [
        { "text": "All challenges complete! The exit at the top is now open.", "emotion": "celebrating", "duration": 3.0 }
      ]
    }
  ],
  "audio": {
    "backgroundMusic": "tower_theme",
    "ambience": "wind_high",
    "soundEffects": {
      "correct": "sfx_correct",
      "wrong": "sfx_wrong",
      "checkpoint": "sfx_checkpoint"
    }
  },
  "rewards": [
    { "type": "star", "amount": 1, "condition": "complete_level" },
    { "type": "star", "amount": 1, "condition": "no_wrong_answers" },
    { "type": "star", "amount": 1, "condition": "collect_all_items" }
  ],
  "difficultyProfile": {
    "adaptive": true,
    "minDifficulty": "easy",
    "maxDifficulty": "hard",
    "escalationRate": 0.4
  }
}
