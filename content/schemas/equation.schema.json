{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathgame.local/schemas/equation.schema.json",
  "title": "Equation",
  "type": "object",
  "required": [
    "id",
    "skill",
    "subskill",
    "prompt",
    "canonicalAnswer",
    "alternateValidAnswers",
    "distractors",
    "difficulty",
    "timePressureScore",
    "workingMemoryScore",
    "representation",
    "hintSteps",
    "tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "skill": { "type": "string" },
    "subskill": { "type": "string" },
    "prompt": { "type": "string" },
    "canonicalAnswer": { "type": "number" },
    "alternateValidAnswers": {
      "type": "array",
      "items": { "type": ["number", "string"] }
    },
    "distractors": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "number" }
    },
    "difficulty": {
      "type": "object",
      "required": [
        "label",
        "conceptualComplexity",
        "arithmeticLoad",
        "numberMagnitude",
        "representationComplexity",
        "timePressureScore",
        "motorCoordinationPressure"
      ],
      "properties": {
        "label": { "type": "string" },
        "conceptualComplexity": { "type": "number", "minimum": 1, "maximum": 10 },
        "arithmeticLoad": { "type": "number", "minimum": 1, "maximum": 10 },
        "numberMagnitude": { "type": "number", "minimum": 1, "maximum": 10 },
        "representationComplexity": { "type": "number", "minimum": 1, "maximum": 10 },
        "timePressureScore": { "type": "number", "minimum": 1, "maximum": 10 },
        "motorCoordinationPressure": { "type": "number", "minimum": 1, "maximum": 10 }
      },
      "additionalProperties": false
    },
    "timePressureScore": { "type": "number", "minimum": 1, "maximum": 10 },
    "workingMemoryScore": { "type": "number", "minimum": 1, "maximum": 10 },
    "representation": { "type": "string" },
    "hintSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
